# Copy to .env for local / RunPod demos. Never commit real secrets.

# Hugging Face (local weights or Inference Router)
HF_TOKEN=

# Local HF demo model (ungated default works without special access)
# ACE_HF_MODEL=Qwen/Qwen2-0.5B-Instruct

# OpenAI-compatible Inference API (HF Router uses HF_TOKEN as the key)
# ACE_LLM_API_BASE=https://router.huggingface.co/v1
# ACE_LLM_API_KEY=
# ACE_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct:novita

# Sandbox / TEE (optional)
# ACE_SANDBOX_BACKEND=process
# ACE_TEE_PLATFORM=simulated
